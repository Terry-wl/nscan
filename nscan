# ==========================================
# CONFIGURACIÓN VISUAL (Dark Hacker Theme)
# ==========================================
RED='\033[0;31m'
GREEN='\033[0;32m'
GRAY='\033[0;90m'
WHITE='\033[0;37m'

B_RED='\033[1;31m'
B_GREEN='\033[1;32m'
B_WHITE='\033[1;37m'
B_GRAY='\033[1;30m'

NC='\033[0m' # Sin color

ICON_TARGET="[►]"
ICON_SCAN="[v]"
ICON_VULN="[☠]"
ICON_UDP="[U]"
ICON_TCP="[T]"
ICON_CHECK="[+]"
ICON_CROSS="[-]"
ICON_WAIT="[~]"
ICON_INFO="[*]"
ICON_ARROW=" >"

SCRIPT_NAME=$(basename "$0")

# ==========================================
# CONTROL DE SEÑALES (Ctrl+C)
# ==========================================
ctrl_c(){
    printf "\n\n${B_RED}${ICON_CROSS} SECUENCIA ABORTADA POR EL USUARIO.${NC}\n"
    tput cnorm; exit 1
}
trap ctrl_c INT

# ==========================================
# VERIFICACIÓN ROOT
# ==========================================
if [ "$(id -u)" != "0" ]; then
    printf "${B_RED}${ICON_CROSS} ACCESO DENEGADO: Se requieren privilegios de ROOT (sudo).${NC}\n"
    exit 1
fi

# Usuario real que invocó sudo (fallback a logname si se ejecuta como root directo)
REAL_USER="${SUDO_USER:-$(logname 2>/dev/null)}"
REAL_GROUP=$(id -gn "$REAL_USER" 2>/dev/null || echo "$REAL_USER")

# ==========================================
# Variables globales y timestamps
# ==========================================
TIMESTAMP=$(date +%Y_%m_%d_%H%M)
SCAN_DIR=$(pwd)
REPORT_FILE="${SCAN_DIR}/reporte_${TIMESTAMP}.html"
DOMAIN_TREE_FILE=$(mktemp)

# Estado de la herramienta (primera ejecución / actualizaciones)
NSCAN_STATE_DIR="/var/lib/nscan"
NSCAN_INIT_MARKER="${NSCAN_STATE_DIR}/.initialized"

# Variables Iniciales
TARGETS=""
SPEED_MODE="normal"
MAX_PARALLEL=1
