HTMLEOF

    rm -f "$RESULTS_TMP" "$DOMAIN_TREE_FILE"

    printf "\n${B_GREEN}${ICON_CHECK} REPORTE HTML GENERADO:${NC} ${B_WHITE}%s${NC}\n" "$REPORT_FILE"

    if [ -n "$REAL_USER" ] && [ "$REAL_USER" != "root" ]; then
        chown "$REAL_USER":"$REAL_GROUP" "$REPORT_FILE"
    fi
}

# ==========================================
# Lógica principal
# ==========================================
tput civis

# Primera ejecución: instalar todo. Ejecuciones siguientes: solo verificar.
if [ ! -f "$NSCAN_INIT_MARKER" ]; then
    install_tools
else
    verify_tools
fi

# -U: actualizar bases de datos y salir
if [ "$DO_UPDATE" -eq 1 ]; then
    printf "\n"
    print_random_banner
    update_databases
    tput cnorm
    exit 0
fi

GLOBAL_START=$(date +%s)

printf "\n"
print_random_banner
print_box \
    "  ${ICON_SCAN} ${B_WHITE}INICIANDO RECONOCIMIENTO${NC}" \
    "$(printf "     ${GRAY}Velocidad:${NC} ${B_WHITE}%s${NC}   ${GRAY}Paralelo:${NC} ${B_WHITE}%s${NC}" "$SPEED_MODE" "$MAX_PARALLEL")"

ACTIVE_JOBS=0

# Detectar si el target es CIDR (solo aplica con -r, target único)
TARGET_WORD_COUNT=$(echo "$TARGETS" | wc -w)
if [ "$TARGET_WORD_COUNT" -eq 1 ] && is_cidr "$TARGETS"; then
    network_discovery "$TARGETS"
    # Si -F, network_discovery ya llamó generate_html y tput cnorm
    if [ "$DO_FULL_PIPELINE" -eq 0 ]; then
        tput cnorm
    fi
else
    for ip in $TARGETS; do
        if [ "$MAX_PARALLEL" -gt 1 ]; then
            scan_host "$ip" &
            ACTIVE_JOBS=$(( ACTIVE_JOBS + 1 ))
            while [ "$ACTIVE_JOBS" -ge "$MAX_PARALLEL" ]; do
                wait -n 2>/dev/null || wait
                ACTIVE_JOBS=$(( ACTIVE_JOBS - 1 ))
            done
        else
            scan_host "$ip"
        fi
    done

    wait
    tput cnorm
    generate_html "$GLOBAL_START"
fi

printf "\n"
print_box \
    "  ${B_GREEN}${ICON_CHECK} RECONOCIMIENTO COMPLETO${NC}" \
    "     ${GRAY}Reportes listos en el directorio actual${NC}"
printf "\n"
